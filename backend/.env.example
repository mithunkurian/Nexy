# ─── Nexy Backend Configuration ─────────────────────────────────────────────

# Server
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-random-secret

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Set ACTIVE_AI_PROVIDER to one of: anthropic | openai | ollama
ACTIVE_AI_PROVIDER=anthropic

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Ollama (local — no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── IKEA Dirigera Hub ───────────────────────────────────────────────────────
# Find your hub IP in the IKEA Home Smart app → Hub settings
DIRIGERA_HOST=192.168.1.100
# Generate token by pressing the action button on the hub, then run:
#   python -c "from dirigera import Hub; h=Hub(token='', ip_address='<IP>'); print(h.create_token())"
DIRIGERA_TOKEN=

# ─── Matter / Thread ─────────────────────────────────────────────────────────
# python-matter-server WebSocket URL
MATTER_SERVER_URL=ws://localhost:5580/ws

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
