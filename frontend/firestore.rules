rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function myUserDoc() {
      return get(myUserPath());
    }

    function isApprovedUser() {
      return isSignedIn() &&
        exists(myUserPath()) &&
        myUserDoc().data.disabled == false &&
        myUserDoc().data.role in ["admin", "family"];
    }

    function isAdmin() {
      return isApprovedUser() && myUserDoc().data.role == "admin";
    }

    match /homeSettings/{doc} {
      allow read: if isApprovedUser();
      allow write: if isAdmin();
    }

    match /userSettings/{uid} {
      allow read: if isAdmin() || request.auth.uid == uid;
      allow write: if isAdmin() || request.auth.uid == uid;
    }

    match /allowedUsers/{email} {
      allow read, write: if isAdmin();
    }

    match /users/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();

      allow create: if request.auth.uid == uid &&
        request.resource.data.email is string &&
        exists(/databases/$(database)/documents/allowedUsers/$(request.resource.data.email)) &&
        get(/databases/$(database)/documents/allowedUsers/$(request.resource.data.email)).data.role == request.resource.data.role &&
        request.resource.data.disabled == false;

      allow update: if isAdmin() ||
        (request.auth.uid == uid &&
         !("role" in request.resource.data.diff(resource.data).affectedKeys()) &&
         !("disabled" in request.resource.data.diff(resource.data).affectedKeys()) &&
         !("email" in request.resource.data.diff(resource.data).affectedKeys()));

      allow delete: if isAdmin();
    }
  }
}
